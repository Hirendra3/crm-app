# Resolve react_native_pods.rb with node to allow for hoisting.
# On WSL, PATH often lists Windows npm shims (/mnt/c/.../npm/node) before Linux Node.
# Prefer NODE_BINARY, then a PATH that skips /mnt/c, then common Linux paths.
require 'shellwords'

def crm_rn_node_executable
  if (explicit = ENV['NODE_BINARY']).is_a?(String) && !explicit.strip.empty?
    return explicit.strip
  end

  sanitized = ENV.fetch('PATH', '').split(':').reject { |d| d.start_with?('/mnt/c') }.compact.join(':')
  found =
    sanitized.empty? ? '' : `env PATH=#{Shellwords.escape(sanitized)} command -v node 2>/dev/null`.strip
  return found unless found.empty?

  ['/usr/bin/node', '/usr/local/bin/node'].each { |p| return p if File.executable?(p) }
  'node'
end

node_executable = crm_rn_node_executable

require Pod::Executable.execute_command(node_executable, ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'CrmMobile' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
